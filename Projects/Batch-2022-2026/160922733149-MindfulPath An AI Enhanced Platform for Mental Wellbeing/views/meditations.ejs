<%- include('partials/header') %>

<% if (page === 'meditation-detail') { %>
<!-- Single Meditation Detail -->
<div class="mb-3">
  <a href="/meditations" class="btn btn-outline-light btn-sm"><i class="bi bi-arrow-left"></i> Back to Library</a>
</div>
<div class="card glass-card p-4">
  <div class="d-flex justify-content-between align-items-start mb-3">
    <div>
      <h2><i class="bi bi-flower1 text-accent"></i> <%= meditation.title %></h2>
      <p class="text-muted"><%= meditation.description %></p>
    </div>
    <div class="text-end">
      <span class="badge bg-accent"><%= meditation.category %></span>
      <br><small class="text-muted"><i class="bi bi-clock"></i> <%= meditation.duration %> min</small>
    </div>
  </div>
  <hr>
  <div class="meditation-content">
    <%- meditation.content.split('\n').join('<br>') %>
  </div>
</div>

<% } else { %>
<!-- Meditation Library -->
<h2 class="mb-4"><i class="bi bi-flower1 text-accent"></i> Meditation Library</h2>

<!-- Category Filters -->
<div class="mb-4 d-flex flex-wrap gap-2">
  <a href="/meditations" class="btn btn-sm <%= selectedCategory === 'all' ? 'btn-accent' : 'btn-outline-light' %>">All</a>
  <% categories.forEach(cat => { %>
  <a href="/meditations?category=<%= cat %>" class="btn btn-sm <%= selectedCategory === cat ? 'btn-accent' : 'btn-outline-light' %>">
    <%= cat.charAt(0).toUpperCase() + cat.slice(1) %>
  </a>
  <% }); %>
</div>

<!-- Meditation Cards -->
<div class="row g-3">
  <% meditations.forEach(m => { %>
  <div class="col-md-4 col-sm-6">
    <a href="/meditations/<%= m.id %>" class="text-decoration-none">
      <div class="card glass-card p-3 hover-card h-100">
        <div class="d-flex justify-content-between align-items-start">
          <span class="badge bg-accent"><%= m.category %></span>
          <small class="text-muted"><i class="bi bi-clock"></i> <%= m.duration %> min</small>
        </div>
        <h5 class="mt-3"><%= m.title %></h5>
        <p class="text-muted small"><%= m.description %></p>
      </div>
    </a>
  </div>
  <% }); %>
</div>

<% if (meditations.length === 0) { %>
<div class="text-center text-muted py-5">
  <i class="bi bi-flower1" style="font-size: 3rem;"></i>
  <h5 class="mt-3">No meditations found</h5>
  <p>Try a different category filter.</p>
</div>
<% } %>
<% } %>

<%- include('partials/footer') %>
