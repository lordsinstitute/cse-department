<%- include('partials/header') %>

<h2 class="mb-4"><i class="bi bi-calendar-check text-accent"></i> Sessions</h2>

<div class="row g-4">
  <% if (user.role === 'user') { %>
  <!-- Book Session Form -->
  <div class="col-md-4">
    <div class="card glass-card p-4">
      <h5><i class="bi bi-calendar-plus text-accent"></i> Book a Session</h5>
      <form method="POST" action="/sessions/book" class="mt-3">
        <div class="mb-3">
          <label class="form-label">Therapist</label>
          <select name="therapist_id" class="form-select" required>
            <option value="">Select a therapist...</option>
            <% therapists.forEach(t => { %>
            <option value="<%= t.id %>"><%= t.name %></option>
            <% }); %>
          </select>
        </div>
        <div class="mb-3">
          <label class="form-label">Date</label>
          <input type="date" name="session_date" class="form-control" required min="<%= new Date().toISOString().split('T')[0] %>">
        </div>
        <div class="mb-3">
          <label class="form-label">Time</label>
          <input type="time" name="session_time" class="form-control" required>
        </div>
        <div class="mb-3">
          <label class="form-label">Duration</label>
          <select name="duration" class="form-select">
            <option value="30">30 minutes</option>
            <option value="45">45 minutes</option>
            <option value="60" selected>60 minutes</option>
            <option value="90">90 minutes</option>
          </select>
        </div>
        <div class="mb-3">
          <label class="form-label">Session Type</label>
          <select name="type" class="form-select">
            <option value="video">Video Call</option>
            <option value="audio">Audio Call</option>
            <option value="chat">Chat</option>
          </select>
        </div>
        <button type="submit" class="btn btn-accent w-100">
          <i class="bi bi-calendar-check"></i> Book Session
        </button>
      </form>
    </div>
  </div>
  <% } %>

  <!-- Sessions List -->
  <div class="<%= user.role === 'user' ? 'col-md-8' : 'col-12' %>">
    <div class="card glass-card p-4">
      <h5><i class="bi bi-list-check text-accent"></i> <%= user.role === 'therapist' ? 'My Patient Sessions' : 'My Sessions' %></h5>
      <% if (sessions.length > 0) { %>
      <div class="table-responsive mt-3">
        <table class="table table-dark table-hover">
          <thead>
            <tr>
              <th><%= user.role === 'therapist' ? 'Patient' : 'Therapist' %></th>
              <th>Date</th>
              <th>Time</th>
              <th>Duration</th>
              <th>Type</th>
              <th>Price</th>
              <th>Status</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            <% sessions.forEach(s => { %>
            <tr>
              <td><%= user.role === 'therapist' ? s.patient_name : s.therapist_name %></td>
              <td><%= s.session_date %></td>
              <td><%= s.session_time %></td>
              <td><%= s.duration %> min</td>
              <td><span class="badge bg-info"><%= s.type %></span></td>
              <td>&#8377;<%= s.price %></td>
              <td>
                <span class="badge <%= s.status === 'scheduled' ? 'bg-primary' : s.status === 'completed' ? 'bg-success' : 'bg-danger' %>">
                  <%= s.status %>
                </span>
              </td>
              <td>
                <% if (s.status === 'scheduled') { %>
                <form method="POST" action="/sessions/<%= s.id %>/cancel" style="display:inline;" onsubmit="return confirm('Cancel this session?')">
                  <button type="submit" class="btn btn-outline-danger btn-sm">
                    <i class="bi bi-x-circle"></i> Cancel
                  </button>
                </form>
                <% } else { %>
                <span class="text-muted">—</span>
                <% } %>
              </td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
      <% } else { %>
      <p class="text-muted mt-3">No sessions yet.</p>
      <% } %>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
