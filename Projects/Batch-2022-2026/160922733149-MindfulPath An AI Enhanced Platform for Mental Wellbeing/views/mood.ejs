<%- include('partials/header') %>

<h2 class="mb-4"><i class="bi bi-emoji-smile text-accent"></i> Mood Tracker</h2>

<div class="row g-4">
  <!-- Log Mood -->
  <div class="col-md-5">
    <div class="card glass-card p-4">
      <h5><i class="bi bi-plus-circle text-accent"></i> Log Your Mood</h5>
      <form method="POST" action="/mood/add" class="mt-3">
        <div class="mb-3">
          <label class="form-label">How are you feeling?</label>
          <div class="mood-picker d-flex justify-content-between gap-2">
            <label class="mood-option">
              <input type="radio" name="mood_score" value="1" required>
              <span class="mood-emoji" title="Very Sad">😢</span>
              <small>Very Sad</small>
            </label>
            <label class="mood-option">
              <input type="radio" name="mood_score" value="2">
              <span class="mood-emoji" title="Sad">😞</span>
              <small>Sad</small>
            </label>
            <label class="mood-option">
              <input type="radio" name="mood_score" value="3">
              <span class="mood-emoji" title="Neutral">😐</span>
              <small>Neutral</small>
            </label>
            <label class="mood-option">
              <input type="radio" name="mood_score" value="4">
              <span class="mood-emoji" title="Happy">😊</span>
              <small>Happy</small>
            </label>
            <label class="mood-option">
              <input type="radio" name="mood_score" value="5">
              <span class="mood-emoji" title="Very Happy">😄</span>
              <small>Very Happy</small>
            </label>
          </div>
        </div>
        <div class="mb-3">
          <label class="form-label">Journal Entry (optional)</label>
          <textarea name="journal_text" class="form-control" rows="4" placeholder="Write about your day, thoughts, or feelings..."></textarea>
          <small class="text-muted">Your journal text will be analyzed using NLP sentiment analysis</small>
        </div>
        <button type="submit" class="btn btn-accent w-100">
          <i class="bi bi-journal-plus"></i> Log Mood
        </button>
      </form>
    </div>
  </div>

  <!-- Chart & History -->
  <div class="col-md-7">
    <div class="card glass-card p-4 mb-4">
      <h5><i class="bi bi-graph-up text-accent"></i> Mood Trend (Last 30 Days)</h5>
      <div style="position: relative; height: 250px;">
        <canvas id="moodTrendChart"></canvas>
      </div>
    </div>

    <div class="card glass-card p-4">
      <h5><i class="bi bi-clock-history text-accent"></i> Recent Entries</h5>
      <% if (entries.length > 0) { %>
      <div class="table-responsive mt-3">
        <table class="table table-dark table-hover">
          <thead><tr><th>Date</th><th>Mood</th><th>Journal</th><th>Sentiment</th></tr></thead>
          <tbody>
            <% entries.forEach(e => { %>
            <tr>
              <td><small><%= new Date(e.created_at).toLocaleDateString() %></small></td>
              <td>
                <% const emojis = {very_sad:'😢', sad:'😞', neutral:'😐', happy:'😊', very_happy:'😄'}; %>
                <span title="<%= e.mood_label %>"><%= emojis[e.mood_label] || '😐' %> (<%= e.mood_score %>/5)</span>
              </td>
              <td><small><%= e.journal_text ? (e.journal_text.length > 50 ? e.journal_text.substring(0,50) + '...' : e.journal_text) : '—' %></small></td>
              <td>
                <% if (e.sentiment_label) { %>
                <span class="badge <%= e.sentiment_label === 'positive' ? 'bg-success' : e.sentiment_label === 'negative' ? 'bg-danger' : 'bg-warning' %>">
                  <%= e.sentiment_label %>
                </span>
                <% } else { %>
                <span class="text-muted">—</span>
                <% } %>
              </td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
      <% } else { %>
      <p class="text-muted mt-3">No mood entries yet. Start logging to see your trends!</p>
      <% } %>
    </div>
  </div>
</div>

<script src="/js/charts.js"></script>
<script>
  fetch('/mood/data')
    .then(r => r.json())
    .then(data => {
      if (data.length > 0) renderMoodChart('moodTrendChart', data);
    });
</script>

<%- include('partials/footer') %>
