<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — MindfulPath</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body>
  <% if (typeof user !== 'undefined' && user) { %>
  <nav class="navbar navbar-expand-lg navbar-dark glass-nav">
    <div class="container">
      <a class="navbar-brand fw-bold" href="/dashboard">
        <i class="bi bi-heart-pulse-fill text-accent"></i> MindfulPath
      </a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navMenu">
        <ul class="navbar-nav me-auto">
          <li class="nav-item">
            <a class="nav-link<%= page === 'dashboard' ? ' active' : '' %>" href="/dashboard">
              <i class="bi bi-speedometer2"></i> Dashboard
            </a>
          </li>
          <% if (user.role === 'user') { %>
          <li class="nav-item">
            <a class="nav-link<%= page === 'chat' ? ' active' : '' %>" href="/chat">
              <i class="bi bi-chat-heart"></i> AI Chat
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link<%= page === 'mood' ? ' active' : '' %>" href="/mood">
              <i class="bi bi-emoji-smile"></i> Mood Tracker
            </a>
          </li>
          <% } %>
          <li class="nav-item">
            <a class="nav-link<%= page === 'meditations' || page === 'meditation-detail' ? ' active' : '' %>" href="/meditations">
              <i class="bi bi-flower1"></i> Meditations
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link<%= page === 'therapists' || page === 'therapist-detail' ? ' active' : '' %>" href="/therapists">
              <i class="bi bi-person-badge"></i> Therapists
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link<%= page === 'sessions' ? ' active' : '' %>" href="/sessions">
              <i class="bi bi-calendar-check"></i> Sessions
            </a>
          </li>
          <% if (user.role === 'admin') { %>
          <li class="nav-item">
            <a class="nav-link<%= page === 'admin-chats' ? ' active' : '' %>" href="/chat/admin/chats">
              <i class="bi bi-shield-lock"></i> Chat History
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link<%= page === 'admin-settings' ? ' active' : '' %>" href="/admin/settings">
              <i class="bi bi-gear"></i> AI Settings
            </a>
          </li>
          <% } %>
          <li class="nav-item">
            <a class="nav-link<%= page === 'about' ? ' active' : '' %>" href="/about">
              <i class="bi bi-info-circle"></i> About
            </a>
          </li>
        </ul>
        <div class="d-flex align-items-center gap-3">
          <span class="badge bg-accent"><%= user.role.charAt(0).toUpperCase() + user.role.slice(1) %></span>
          <span class="text-light"><i class="bi bi-person-circle"></i> <%= user.name %></span>
          <a href="/logout" class="btn btn-outline-light btn-sm">
            <i class="bi bi-box-arrow-right"></i> Logout
          </a>
        </div>
      </div>
    </div>
  </nav>
  <% } %>

  <div class="container py-4">
    <% if (typeof success !== 'undefined' && success) { %>
    <div class="alert alert-success alert-dismissible fade show" role="alert">
      <i class="bi bi-check-circle"></i> <%= success %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    <% } %>
    <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
      <i class="bi bi-exclamation-circle"></i> <%= error %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    <% } %>
