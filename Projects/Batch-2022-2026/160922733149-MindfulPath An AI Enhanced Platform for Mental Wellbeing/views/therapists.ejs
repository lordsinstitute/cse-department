<%- include('partials/header') %>

<% if (page === 'therapist-detail') { %>
<!-- Therapist Profile -->
<div class="mb-3">
  <a href="/therapists" class="btn btn-outline-light btn-sm"><i class="bi bi-arrow-left"></i> Back to Directory</a>
</div>
<div class="card glass-card p-4">
  <div class="row">
    <div class="col-md-8">
      <h2><i class="bi bi-person-badge text-accent"></i> <%= therapist.name %></h2>
      <p class="text-muted"><%= therapist.bio %></p>
      <hr>
      <div class="row g-3">
        <div class="col-md-6">
          <h6 class="text-accent">Specialties</h6>
          <div class="d-flex flex-wrap gap-1">
            <% therapist.specialties_arr.forEach(s => { %>
            <span class="badge bg-secondary"><%= s %></span>
            <% }); %>
          </div>
        </div>
        <div class="col-md-6">
          <h6 class="text-accent">Education</h6>
          <p><%= therapist.education %></p>
        </div>
        <div class="col-md-6">
          <h6 class="text-accent">Therapeutic Approach</h6>
          <p><%= therapist.approach || 'Not specified' %></p>
        </div>
        <div class="col-md-6">
          <h6 class="text-accent">Languages</h6>
          <p><%= therapist.languages %></p>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card glass-card p-3 text-center">
        <i class="bi bi-person-circle text-accent" style="font-size: 4rem;"></i>
        <h5 class="mt-2"><%= therapist.name %></h5>
        <p class="text-muted"><%= therapist.experience %> years experience</p>
        <p class="text-accent fw-bold" style="font-size: 1.5rem;">&#8377;<%= therapist.session_price %>/session</p>
        <p class="small text-muted">License: <%= therapist.license %></p>
        <a href="/sessions" class="btn btn-accent w-100 mt-2">
          <i class="bi bi-calendar-plus"></i> Book Session
        </a>
      </div>
    </div>
  </div>
</div>

<% } else { %>
<!-- Therapist Directory -->
<h2 class="mb-4"><i class="bi bi-person-badge text-accent"></i> Therapist Directory</h2>

<div class="row g-3">
  <% therapists.forEach(t => { %>
  <div class="col-md-6">
    <a href="/therapists/<%= t.id %>" class="text-decoration-none">
      <div class="card glass-card p-4 hover-card h-100">
        <div class="d-flex gap-3">
          <div>
            <i class="bi bi-person-circle text-accent" style="font-size: 3rem;"></i>
          </div>
          <div class="flex-grow-1">
            <h5 class="mb-1"><%= t.name %></h5>
            <p class="text-muted small mb-2"><%= t.experience %> years experience</p>
            <div class="d-flex flex-wrap gap-1 mb-2">
              <% t.specialties_arr.forEach(s => { %>
              <span class="badge bg-secondary"><%= s %></span>
              <% }); %>
            </div>
            <div class="d-flex justify-content-between align-items-center">
              <span class="text-accent fw-bold">&#8377;<%= t.session_price %>/session</span>
              <small class="text-muted"><%= t.languages %></small>
            </div>
          </div>
        </div>
      </div>
    </a>
  </div>
  <% }); %>
</div>

<% if (therapists.length === 0) { %>
<div class="text-center text-muted py-5">
  <i class="bi bi-person-badge" style="font-size: 3rem;"></i>
  <h5 class="mt-3">No therapists available</h5>
</div>
<% } %>
<% } %>

<%- include('partials/footer') %>
