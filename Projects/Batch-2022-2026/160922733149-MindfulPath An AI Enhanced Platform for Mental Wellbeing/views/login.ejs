<%- include('partials/header') %>

<div class="row justify-content-center mt-5">
  <div class="col-md-5">
    <div class="card glass-card p-4">
      <div class="text-center mb-4">
        <i class="bi bi-heart-pulse-fill text-accent" style="font-size: 3rem;"></i>
        <h2 class="mt-2">MindfulPath</h2>
        <p class="text-muted">AI-Powered Mental Wellbeing Platform</p>
      </div>
      <form method="POST" action="/login">
        <div class="mb-3">
          <label class="form-label"><i class="bi bi-envelope"></i> Email</label>
          <input type="email" name="email" class="form-control" placeholder="Enter your email" required>
        </div>
        <div class="mb-3">
          <label class="form-label"><i class="bi bi-lock"></i> Password</label>
          <input type="password" name="password" class="form-control" placeholder="Enter your password" required>
        </div>
        <button type="submit" class="btn btn-accent w-100 mb-3">
          <i class="bi bi-box-arrow-in-right"></i> Login
        </button>
      </form>
      <div class="text-center">
        <span class="text-muted">Don't have an account?</span>
        <a href="/register" class="text-accent">Register here</a>
      </div>
      <hr class="my-3">
      <div class="small text-muted">
        <strong>Demo Accounts:</strong><br>
        Admin: admin@mindfulpath.com / admin123<br>
        Therapist: dr.sarah@mindfulpath.com / doctor123<br>
        User: patient@mindfulpath.com / patient123
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
