<%- include('partials/header') %>

<div class="row g-0 chat-container">
  <!-- Sidebar -->
  <div class="col-md-3 chat-sidebar">
    <div class="p-3">
      <button class="btn btn-accent w-100 mb-3" id="newChatBtn">
        <i class="bi bi-plus-circle"></i> New Chat
      </button>
      <h6 class="text-muted mb-2">Chat History</h6>
      <div id="chatSessionsList">
        <% chatSessions.forEach(s => { %>
        <div class="chat-session-item" data-id="<%= s.id %>">
          <small class="text-muted"><%= new Date(s.started_at).toLocaleDateString() %> <%= new Date(s.started_at).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %></small>
          <br><span class="badge bg-secondary"><%= s.message_count %> messages</span>
          <% if (s.avg_sentiment !== null) { %>
          <span class="badge <%= s.avg_sentiment > 0.1 ? 'bg-success' : s.avg_sentiment < -0.1 ? 'bg-danger' : 'bg-warning' %>">
            <%= s.avg_sentiment > 0.1 ? 'Positive' : s.avg_sentiment < -0.1 ? 'Negative' : 'Neutral' %>
          </span>
          <% } %>
        </div>
        <% }); %>
      </div>
    </div>
  </div>

  <!-- Chat Area -->
  <div class="col-md-9 d-flex flex-column">
    <!-- Crisis Banner -->
    <div class="crisis-banner">
      <i class="bi bi-telephone-fill"></i> If you're in crisis, call <strong>Vandrevala Foundation: 1860-2662-345</strong> (24/7) | iCall: 9152987821 | AASRA: 9820466726
    </div>

    <!-- Messages -->
    <div class="chat-messages flex-grow-1" id="chatMessages">
      <div class="text-center text-muted py-5" id="chatPlaceholder">
        <i class="bi bi-chat-heart" style="font-size: 3rem;"></i>
        <h5 class="mt-3">Welcome to MindfulPath AI Chat</h5>
        <p>Click "New Chat" to start a conversation with your wellness companion.</p>
        <p class="small">Your conversations are private and analyzed using NLP sentiment analysis to provide personalized CBT-based responses.</p>
      </div>
    </div>

    <!-- Input -->
    <div class="chat-input-area p-3" id="chatInputArea" style="display: none;">
      <form id="chatForm" class="d-flex gap-2">
        <input type="text" id="chatInput" class="form-control" placeholder="Type your message..." autocomplete="off">
        <button type="submit" class="btn btn-accent" id="sendBtn">
          <i class="bi bi-send-fill"></i>
        </button>
      </form>
    </div>
  </div>
</div>

<script src="/js/chat.js"></script>

<%- include('partials/footer') %>
