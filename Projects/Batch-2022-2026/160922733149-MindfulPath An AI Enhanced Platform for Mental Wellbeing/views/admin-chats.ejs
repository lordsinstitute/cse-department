<%- include('partials/header') %>

<div class="d-flex align-items-center gap-2 mb-4">
  <% if (typeof messages !== 'undefined') { %>
    <a href="/chat/admin/chats/user/<%= session.user_id %>" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
    <h4 class="mb-0"><i class="bi bi-chat-text text-accent"></i> Session — <span class="text-muted fs-6"><%= session.user_name %> (<%= session.user_email %>)</span></h4>
  <% } else if (typeof sessions !== 'undefined') { %>
    <a href="/chat/admin/chats" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
    <h4 class="mb-0"><i class="bi bi-person-lines-fill text-accent"></i> <%= patient.name %>'s Chat Sessions</h4>
  <% } else { %>
    <a href="/dashboard" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
    <h4 class="mb-0"><i class="bi bi-shield-lock text-accent"></i> User Chat History</h4>
  <% } %>
</div>

<% if (typeof messages !== 'undefined') { %>
<!-- ── SESSION MESSAGE VIEW ── -->
<div class="card glass-card p-3 mb-3">
  <div class="d-flex flex-wrap gap-3 small text-muted">
    <span><i class="bi bi-person-circle"></i> <strong><%= session.user_name %></strong> (<%= session.user_role %>)</span>
    <span><i class="bi bi-clock"></i> <%= new Date(session.started_at).toLocaleString() %></span>
    <span><i class="bi bi-chat-dots"></i> <%= session.message_count %> messages</span>
    <% if (session.avg_sentiment !== null) { %>
    <span class="badge <%= session.avg_sentiment > 0.1 ? 'bg-success' : session.avg_sentiment < -0.1 ? 'bg-danger' : 'bg-warning text-dark' %>">
      Avg Sentiment: <%= session.avg_sentiment > 0.1 ? 'Positive' : session.avg_sentiment < -0.1 ? 'Negative' : 'Neutral' %>
    </span>
    <% } %>
  </div>
</div>

<div class="card glass-card p-3" style="max-height: 65vh; overflow-y: auto;">
  <% messages.forEach(m => { %>
  <div class="d-flex mb-3 <%= m.role === 'user' ? 'justify-content-end' : 'justify-content-start' %>">
    <div style="max-width: 75%;">
      <div class="px-3 py-2 rounded-3 <%= m.role === 'user' ? 'bg-primary text-white' : 'bg-secondary bg-opacity-25' %>"
           style="white-space: pre-wrap; word-break: break-word;">
        <%- m.message.replace(/\n/g, '<br>') %>
      </div>
      <div class="d-flex gap-2 mt-1 px-1" style="font-size: 0.72rem;">
        <span class="text-muted"><%= new Date(m.created_at).toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'}) %></span>
        <% if (m.role === 'user' && m.sentiment_label) { %>
        <span class="badge <%= m.sentiment_label.includes('negative') ? 'bg-danger' : m.sentiment_label === 'positive' ? 'bg-success' : 'bg-secondary' %> bg-opacity-75">
          <%= m.sentiment_label.replace('_', ' ') %>
        </span>
        <% } %>
        <% if (m.role === 'bot' && m.technique) { %>
        <span class="text-muted"><i class="bi bi-lightbulb"></i> <%= m.technique.replace(/_/g, ' ') %></span>
        <% } %>
      </div>
    </div>
  </div>
  <% }); %>
</div>

<% } else if (typeof sessions !== 'undefined') { %>
<!-- ── USER'S SESSION LIST ── -->
<div class="card glass-card p-3 mb-3 small text-muted">
  <i class="bi bi-envelope"></i> <%= patient.email %> &nbsp;|&nbsp;
  <span class="badge bg-info"><%= patient.role %></span>
</div>

<% if (sessions.length === 0) { %>
<div class="card glass-card p-4 text-center text-muted">
  <i class="bi bi-chat-slash" style="font-size:2rem;"></i>
  <p class="mt-2">No chat sessions found for this user.</p>
</div>
<% } else { %>
<div class="row g-3">
  <% sessions.forEach((s, i) => { %>
  <div class="col-md-6">
    <a href="/chat/admin/chats/session/<%= s.id %>" class="text-decoration-none">
      <div class="card glass-card p-3 hover-card">
        <div class="d-flex justify-content-between align-items-start">
          <div>
            <strong>Session #<%= sessions.length - i %></strong>
            <div class="text-muted small mt-1">
              <i class="bi bi-clock"></i> <%= new Date(s.started_at).toLocaleString() %>
            </div>
            <div class="mt-1">
              <span class="badge bg-secondary"><%= s.message_count %> messages</span>
              <% if (s.avg_sentiment !== null) { %>
              <span class="badge <%= s.avg_sentiment > 0.1 ? 'bg-success' : s.avg_sentiment < -0.1 ? 'bg-danger' : 'bg-warning text-dark' %>">
                <%= s.avg_sentiment > 0.1 ? 'Positive' : s.avg_sentiment < -0.1 ? 'Negative' : 'Neutral' %>
              </span>
              <% } %>
            </div>
          </div>
          <i class="bi bi-chevron-right text-muted"></i>
        </div>
      </div>
    </a>
  </div>
  <% }); %>
</div>
<% } %>

<% } else { %>
<!-- ── ALL USERS LIST ── -->
<div class="card glass-card p-0">
  <div class="table-responsive">
    <table class="table table-dark table-hover mb-0">
      <thead>
        <tr>
          <th>Name</th>
          <th>Email</th>
          <th>Role</th>
          <th class="text-center">Sessions</th>
          <th class="text-center">Messages</th>
          <th>Last Chat</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% users.forEach(u => { %>
        <tr>
          <td><i class="bi bi-person-circle text-muted me-1"></i><%= u.name %></td>
          <td class="text-muted small"><%= u.email %></td>
          <td><span class="badge <%= u.role === 'therapist' ? 'bg-info' : 'bg-secondary' %>"><%= u.role %></span></td>
          <td class="text-center"><%= u.session_count || 0 %></td>
          <td class="text-center"><%= u.total_messages || 0 %></td>
          <td class="small text-muted">
            <%= u.last_chat ? new Date(u.last_chat).toLocaleString() : '—' %>
          </td>
          <td>
            <a href="/chat/admin/chats/user/<%= u.id %>" class="btn btn-sm btn-outline-accent">
              <i class="bi bi-eye"></i> View
            </a>
          </td>
        </tr>
        <% }); %>
        <% if (users.length === 0) { %>
        <tr><td colspan="7" class="text-center text-muted py-4">No users found.</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>
<% } %>

<%- include('partials/footer') %>
