"""
Splunk HTTP Event Collector (HEC) integration.

Sends alert events to Splunk when SPLUNK_HEC_URL and SPLUNK_HEC_TOKEN are set.
"""

import json
from typing import Any, Dict, Optional

import requests

from app.config import SPLUNK_HEC_TOKEN, SPLUNK_HEC_URL, SPLUNK_INDEX
from app.core.logging import get_logger

logger = get_logger(__name__)


def send_alert_to_splunk(alert: Dict[str, Any]) -> bool:
    """
    POST a single alert to Splunk HEC.
    Returns True if sent successfully, False otherwise.
    """
    if not SPLUNK_HEC_URL or not SPLUNK_HEC_TOKEN:
        return False
    from datetime import datetime

def serialize(obj):
    if isinstance(obj, datetime):
        return obj.isoformat()
    return obj

safe_alert = {k: serialize(v) for k, v in alert.items()}

payload = {
    "event": safe_alert,
    "sourcetype": "nids:alert",
    "index": SPLUNK_INDEX,
}

headers = {
        "Authorization": f"Splunk {SPLUNK_HEC_TOKEN}",
        "Content-Type": "application/json",
}
try:
    r = requests.post(SPLUNK_HEC_URL, json=payload, headers=headers, timeout=5)
    if r.status_code in (200, 201):
        return True
    logger.warning("Splunk HEC returned %s: %s", r.status_code, r.text[:200])
except Exception as e:
    logger.warning("Splunk HEC send failed: %s", e)
return False


